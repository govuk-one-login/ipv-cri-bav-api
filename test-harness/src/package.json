{
  "name": "test-harness",
  "version": "1.0.0",
  "description": "Harness to enable automation testing",
  "main": "index.js",
  "scripts": {
    "compile": "./node_modules/.bin/tsc",
    "unit": "./node_modules/.bin/jest --testPathPatterns=tests/unit --coverage",
    "test:unit": "npm run compile && npm run unit",
    "lint": "./node_modules/.bin/eslint '*.ts'",
    "lint:fix": "eslint --fix --output-file ./reports/eslint/report.html --format html -c eslint.config.mjs --ext .ts ."
  },
  "author": "GDS",
  "license": "MIT",
  "dependencies": {
    "@aws-lambda-powertools/logger": "1.5.1",
    "@aws-lambda-powertools/metrics": "1.5.1",
    "@aws-sdk/client-athena": "3.1045.0",
    "@aws-sdk/client-s3": "3.1045.0",
    "@smithy/node-http-handler": "4.0.4",
    "esbuild": "0.25.2"
  },
  "devDependencies": {
    "@babel/preset-typescript": "7.22.5",
    "@types/aws-lambda": "8.10.148",
    "@types/jest": "29.5.14",
    "@types/node": "20.14.8",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "aws-sdk-client-mock": "4.0.1",
    "aws-sdk-client-mock-jest": "4.0.1",
    "eslint": "10.0.2",
    "jest": "30.2.0",
    "jest-junit": "17.0.0",
    "jest-mock-extended": "4.0.0",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typescript": "5.1.6"
  },
  "babel": {
    "presets": [
      "@babel/preset-typescript"
    ]
  },
  "engines": {
   "node": "22.*"
  },
  "type": "module"
}
